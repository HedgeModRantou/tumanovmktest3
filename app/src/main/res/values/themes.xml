<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Tumanovmktest3" parent="Theme.AppCompat.Light.DarkActionBar">

        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>

        <item name="android:windowBackground">@color/background</item>
        <item name="android:colorBackground">@color/background</item>

        <item name="actionBarStyle">@style/CustomActionBar</item>
        <item name="actionMenuTextColor">@color/drawer_header_text</item>

        <item name="colorControlActivated">@color/primary</item>

        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <item name="bottomNavigationStyle">@style/BottomNav</item>

    </style>

    <style name="CustomActionBar" parent="Widget.AppCompat.ActionBar.Solid">
        <item name="background">@color/drawer_header_bg</item>
        <item name="titleTextStyle">@style/ActionBarTitle</item>
        <item name="subtitleTextStyle">@style/ActionBarSubtitle</item>
    </style>

    <style name="ActionBarTitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/drawer_header_text</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ActionBarSubtitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Subtitle">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/bottom_nav_bg</item>
        <item name="itemIconTint">@color/bottom_nav_item</item>
        <item name="itemTextColor">@color/bottom_nav_item</item>
    </style>

</resources>
